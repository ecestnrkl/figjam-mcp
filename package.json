{
  "name": "figjam-context-mcp",
  "version": "0.3.0",
  "description": "MCP server that turns a FigJam board into queryable context for LLMs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    ".env.example",
    "docs/pipeline.gif"
  ],
  "bin": {
    "figjam-context-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "npm run clean && tsc -p tsconfig.json",
    "postbuild": "node scripts/postbuild.mjs",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json",
    "typecheck": "npm run typecheck:src && npm run typecheck:tests",
    "test": "vitest run",
    "check": "npm run typecheck && npm test && npm run build && npm run package:check",
    "package:check": "node scripts/check-package.mjs",
    "package:smoke": "node scripts/package-smoke.mjs",
    "prepack": "npm run check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "dotenv": "^16.4.5",
    "openai": "^6.45.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
