# Figma personal access token
# figma.com → Settings → Security → Personal access tokens
FIGMA_ACCESS_TOKEN=

# --- LLM (vision interpretation + answer synthesis) ---------------------
# Any OpenAI-compatible chat completions endpoint works. Two free options:
#
# 1) OpenRouter (default): create a key at https://openrouter.ai/keys.
#    The student-free preset uses explicit free models instead of the generic
#    openrouter/free router so JSON output and vision support are more stable.
#
# 2) GitHub Models: free with any GitHub account
#    (https://github.com/marketplace/models) — set
#    LLM_BASE_URL=https://models.github.ai/inference and use a GitHub PAT
#    as LLM_API_KEY, with a vision-capable model id.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
# Supported presets: student-free
LLM_MODEL_PRESET=student-free
# Optional role-specific overrides. Legacy LLM_VISION_MODEL / LLM_TEXT_MODEL
# still work and become the first candidate in each list.
# LLM_VISION_MODELS=google/gemma-4-26b-a4b-it:free,openrouter/free
# LLM_TEXT_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,nvidia/nemotron-nano-9b-v2:free,openrouter/free
# LLM_FAST_TEXT_MODELS=nvidia/nemotron-nano-9b-v2:free,liquid/lfm-2.5-1.2b-instruct:free
# LLM_PROVIDER_REQUIRE_PARAMETERS=true

# --- Timeout controls ----------------------------------------------------
# Defaults are tuned so MCP UI clients do not wait forever on slow providers.
# Increase these only if your MCP client/request timeout is also higher.
# FIGMA_REQUEST_TIMEOUT_MS=15000
# FIGMA_FILE_REQUEST_TIMEOUT_MS=60000
# LLM_REQUEST_TIMEOUT_MS=20000
# LLM_RATE_LIMIT_RETRIES=1
# LLM_RATE_LIMIT_MAX_BACKOFF_MS=5000
# LLM_MAX_OUTPUT_TOKENS=14096
# LLM_ANSWER_MAX_OUTPUT_TOKENS=800
# INGEST_BOARD_VISION_BUDGET_MS=35000
# INGEST_BOARD_MIN_VISION_SLOT_MS=10000
# FIGMA_SCREENSHOT_DOWNLOAD_CONCURRENCY=3
