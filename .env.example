# Figma personal access token
# figma.com → Settings → Security → Personal access tokens
FIGMA_ACCESS_TOKEN=

# --- LLM (vision interpretation + answer synthesis) ---------------------
# Any OpenAI-compatible chat completions endpoint works. Two free options:
#
# 1) OpenRouter (default): create a key at https://openrouter.ai/keys
#    "openrouter/free" is OpenRouter's Free Models Router — it auto-selects
#    a currently available free model that supports the request's features
#    (including image input), so it keeps working when individual :free
#    models disappear. Free tier: ~20 requests/min, 200/day.
#
# 2) GitHub Models: free with any GitHub account
#    (https://github.com/marketplace/models) — set
#    LLM_BASE_URL=https://models.github.ai/inference and use a GitHub PAT
#    as LLM_API_KEY, with a vision-capable model id.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
# Same model may serve both roles; kept separate so they're easy to split.
LLM_VISION_MODEL=openrouter/free
LLM_TEXT_MODEL=openrouter/free
